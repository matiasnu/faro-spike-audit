# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for remediation prompts
CLAUDE_MODEL=claude-sonnet-4-6

# FastAPI server
HOST=0.0.0.0
PORT=8000

# Playwright timeout in milliseconds for page load
PAGE_LOAD_TIMEOUT_MS=30000

# Maximum number of violations to remediate per scan (cost control during spike)
MAX_REMEDIATIONS=10

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
