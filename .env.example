# Enable LLM-backed remediation as the last tier of the cascade.
# Default false: the spike runs end-to-end with deterministic + heuristic
# strategies only (zero token cost). Set to true once an API key is available.
ENABLE_AI_REMEDIATION=false

# LLM provider to use when ENABLE_AI_REMEDIATION=true
# Supported values: "groq" (recommended for free tier), "anthropic"
LLM_PROVIDER=groq

# --- Groq provider config (recommended free tier) ---
# Free API key (no credit card) from https://console.groq.com/keys
# Free tier: 1000 req/day, sub-200ms latency, does NOT train on your data.
GROQ_API_KEY=gsk_...
# Model: llama-3.3-70b-versatile is the default — 88.4% HumanEval, on par
# with Claude Sonnet for HTML/CSS/ARIA generation.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic provider config (only needed if LLM_PROVIDER=anthropic) ---
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model identifier
CLAUDE_MODEL=claude-sonnet-4-6

# FastAPI server
HOST=0.0.0.0
PORT=8000

# Playwright timeout in milliseconds for page load
PAGE_LOAD_TIMEOUT_MS=30000

# Maximum number of violations to remediate per scan (cost control during spike)
MAX_REMEDIATIONS=10

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
